{
  "name": "IronLog Pro",
  "short_name": "IronLog",
  "id": "/",
  "scope": "/",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "background_color": "#09090b",
  "theme_color": "#dc2626",
  "orientation": "portrait-primary",
  "lang": "es",
  "dir": "ltr",
  "categories": [
    "fitness",
    "health",
    "productivity"
  ],
  "description": "Seguimiento profesional de hipertrofia con progresión estilo RP, analytics y soporte offline.",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home — Active Mesocycle"
    },
    {
      "src": "/screenshot-workout.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Workout Tracker"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Workout",
      "short_name": "Workout",
      "description": "Jump straight to your next session",
      "url": "/?action=start&source=shortcut",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?action=share_target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "display_override": [
    "standalone",
    "window-controls-overlay",
    "minimal-ui"
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "protocol_handlers": [
    {
      "protocol": "web+ironlog",
      "url": "/?action=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/?action=import_workout",
      "accept": {
        "application/json": [
          ".json"
        ]
      }
    }
  ],
  "note_taking": {
    "new_note_url": "/?action=new_note"
  },
  "widgets": [
    {
      "name": "IronLog Active Routine",
      "short_name": "Routine",
      "description": "View your active workout routine",
      "tag": "workout",
      "template_url": "https://iron-log-react.vercel.app/widgets/workout.json",
      "ms_ac_template": "https://iron-log-react.vercel.app/widgets/workout.json",
      "data": "https://iron-log-react.vercel.app/widgets/data.json",
      "type": "application/json",
      "auth": false,
      "update": 86400
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://iron-log-react.vercel.app/manifest.json"
    }
  ],
  "iarc_rating_id": "",
  "scope_extensions": [
    {
      "origin": "https://*.iron-log-react.vercel.app"
    }
  ]
}